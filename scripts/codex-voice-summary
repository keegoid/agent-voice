#!/usr/bin/env bash
# Strict helper: generate and optionally play a Codex turn summary.

set -euo pipefail

server_url="${CODEX_TTS_SERVER:-http://127.0.0.1:8880}"
voice="${CODEX_TTS_VOICE:-peng_mythic}"
instruct=""
output=""
play=1

usage() {
  cat >&2 <<'USAGE'
Usage:
  codex-voice-summary [options] "summary text"
  echo "summary text" | codex-voice-summary [options]

Options:
  -v, --voice NAME      Voice name. Default: peng_mythic.
  -i, --instruct TEXT   Custom voice-design prompt; skips server voice lookup.
  -s, --server URL      TTS server URL. Default: http://127.0.0.1:8880.
  -o, --output PATH     Save WAV to PATH instead of a temp file.
  --no-play             Generate WAV but do not play it.
  -h, --help            Show this help.
USAGE
}

while [[ $# -gt 0 ]]; do
  case "$1" in
    -v|--voice)
      [[ $# -ge 2 ]] || { echo "Missing value for $1" >&2; exit 2; }
      voice="$2"
      shift 2
      ;;
    -s|--server)
      [[ $# -ge 2 ]] || { echo "Missing value for $1" >&2; exit 2; }
      server_url="${2%/}"
      shift 2
      ;;
    -i|--instruct)
      [[ $# -ge 2 ]] || { echo "Missing value for $1" >&2; exit 2; }
      instruct="$2"
      shift 2
      ;;
    -o|--output)
      [[ $# -ge 2 ]] || { echo "Missing value for $1" >&2; exit 2; }
      output="$2"
      shift 2
      ;;
    --no-play)
      play=0
      shift
      ;;
    -h|--help)
      usage
      exit 0
      ;;
    --)
      shift
      break
      ;;
    -*)
      echo "Unknown option: $1" >&2
      usage
      exit 2
      ;;
    *)
      break
      ;;
  esac
done

if [[ $# -gt 0 ]]; then
  text="$*"
else
  if [[ -t 0 ]]; then
    echo "No summary text provided" >&2
    exit 2
  fi
  text="$(cat)"
fi

text="${text#"${text%%[![:space:]]*}"}"
text="${text%"${text##*[![:space:]]}"}"
[[ -n "$text" ]] || { echo "No summary text provided" >&2; exit 2; }

command -v curl >/dev/null || { echo "curl not found" >&2; exit 1; }
command -v jq >/dev/null || { echo "jq not found" >&2; exit 1; }
if [[ "$play" -eq 1 ]]; then
  command -v afplay >/dev/null || { echo "afplay not found" >&2; exit 1; }
fi

health="$(curl -fsS --max-time 3 "$server_url/v1/health")" || {
  echo "TTS server not reachable at $server_url" >&2
  exit 1
}

if [[ -z "$instruct" ]] && ! jq -e --arg voice "$voice" '.voices | index($voice)' >/dev/null <<<"$health"; then
  voices="$(jq -r '.voices | join(", ")' <<<"$health")"
  echo "Unknown voice '$voice'. Available: $voices" >&2
  exit 1
fi

if [[ -n "$output" ]]; then
  wav="$output"
  cleanup=0
else
  wav="$(mktemp "${TMPDIR:-/tmp}/codex-voice-summary.XXXXXX")"
  cleanup=1
fi

finish() {
  if [[ "${cleanup:-0}" -eq 1 && -n "${wav:-}" ]]; then
    rm -f "$wav"
  fi
}
trap finish EXIT

payload="$(
  jq -n \
    --arg model "qwen3-tts" \
    --arg input "$text" \
    --arg voice "$voice" \
    --arg instruct "$instruct" \
    --arg response_format "wav" \
    '{model: $model, input: $input, voice: $voice, response_format: $response_format}
      + (if $instruct == "" then {} else {instruct: $instruct} end)'
)"

curl -fsS --max-time 180 \
  -H 'Content-Type: application/json' \
  -d "$payload" \
  "$server_url/v1/audio/speech" \
  -o "$wav"

if [[ "$play" -eq 1 ]]; then
  afplay "$wav"
fi

if [[ "$cleanup" -eq 0 ]]; then
  echo "$wav"
fi
