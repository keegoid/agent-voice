#!/usr/bin/env bash
# Manage an installed agent-voice service and backups.

set -euo pipefail

DEFAULT_STATE_DIR="$HOME/.agent-voice"
if [[ -n "${AGENT_VOICE_HOME:-}" ]]; then
  STATE_DIR="$AGENT_VOICE_HOME"
else
  STATE_DIR="$DEFAULT_STATE_DIR"
fi
LABEL="com.keegoid.agent-voice"
DOMAIN="gui/$(id -u)"
PLIST="$HOME/Library/LaunchAgents/$LABEL.plist"
LOCAL_BIN="$HOME/.local/bin"

legacy_name() {
  printf '%s%s\n' "codex" "-tts"
}

legacy_label() {
  printf 'com.keegoid.%s\n' "$(legacy_name)"
}

legacy_state_dir() {
  printf '%s/.%s\n' "$HOME" "$(legacy_name)"
}

legacy_plist_path() {
  printf '%s/Library/LaunchAgents/%s.plist\n' "$HOME" "$(legacy_label)"
}

legacy_shim_names() {
  printf '%s\n' "$(legacy_name)" "codex""-speak" "codex""-voice-summary"
}

legacy_shim_marker() {
  printf '# %s-managed-shim\n' "$(legacy_name)"
}

usage() {
  cat <<'USAGE'
Usage: agent-voice <command>

Commands:
  status
  start
  stop
  restart
  logs
  configure hermes [--dry-run] [--restart-gateway] [--server URL] [--voice NAME]
  restore [--list|--backup <id>]
  uninstall [--destroy-caches]
USAGE
}

backup_root() {
  printf '%s/backups\n' "$STATE_DIR"
}

backup_path() {
  target="$1"
  [[ -e "$target" ]] || return 0
  home_prefix="$HOME/"
  backup_id="$(date '+%Y%m%d%H%M%S')-uninstall-$$"
  if [[ "$target" == "$home_prefix"* ]]; then
    rel="home/${target#"$home_prefix"}"
  else
    rel="external/${target#/}"
  fi
  dest="$(backup_root)/$backup_id/$rel"
  mkdir -p "$(dirname "$dest")"
  cp -a "$target" "$dest"
}

latest_backup() {
  find "$(backup_root)" -mindepth 1 -maxdepth 1 -type d 2>/dev/null | sort | tail -n 1
}

oldest_backup_with() {
  name="$1"
  rel="home/.local/bin/$name"
  while IFS= read -r backup; do
    if [[ -f "$backup/$rel" ]] && ! is_managed_shim "$backup/$rel" "$name"; then
      printf '%s\n' "$backup/$rel"
      return 0
    fi
  done < <(find "$(backup_root)" -mindepth 1 -maxdepth 1 -type d 2>/dev/null | sort)
  return 1
}

is_managed_shim() {
  file="$1"
  name="$2"
  grep -Fq "# agent-voice-managed-shim" "$file" 2>/dev/null && return 0
  grep -Eq "exec \".*/\\.agent-voice/bin/$name\"" "$file" 2>/dev/null
}

is_managed_legacy_shim() {
  file="$1"
  name="$2"
  grep -Fq "# agent-voice-managed-shim" "$file" 2>/dev/null && return 0
  grep -Fq "$(legacy_shim_marker)" "$file" 2>/dev/null && return 0
  grep -Eq "exec \".*/\\.$(legacy_name)/bin/$name\"" "$file" 2>/dev/null
}

restore_or_remove_shim() {
  name="$1"
  shim="$LOCAL_BIN/$name"
  [[ -e "$shim" ]] || return 0
  if ! is_managed_shim "$shim" "$name"; then
    echo "Skipping unmanaged shim $shim"
    return 0
  fi

  saved="$(oldest_backup_with "$name" || true)"
  if [[ -n "$saved" ]]; then
    mkdir -p "$(dirname "$shim")"
    cp -a "$saved" "$shim"
    echo "Restored previous shim $shim"
  else
    rm -f "$shim"
    echo "Removed shim $shim"
  fi
}

remove_legacy_artifacts() {
  destroy_caches="${1:-0}"
  old_label="$(legacy_label)"
  old_plist="$(legacy_plist_path)"
  old_state="$(legacy_state_dir)"
  launchctl bootout "$DOMAIN/$old_label" 2>/dev/null || launchctl bootout "$DOMAIN" "$old_plist" 2>/dev/null || true
  while IFS= read -r shim_name; do
    shim="$LOCAL_BIN/$shim_name"
    if [[ -e "$shim" ]] && is_managed_legacy_shim "$shim" "$shim_name"; then
      backup_path "$shim"
      rm -f "$shim"
      echo "Removed shim $shim"
    fi
  done < <(legacy_shim_names)
  backup_path "$old_plist"
  rm -f "$old_plist"
  if [[ -d "$old_state" ]]; then
    backup_path "$old_state/app"
    backup_path "$old_state/bin"
    rm -rf "$old_state/app" "$old_state/bin"
    if [[ "$destroy_caches" -eq 1 ]]; then
      rm -rf "$old_state/model-cache"
    fi
    rmdir "$old_state" 2>/dev/null || true
  fi
}

restore_backup() {
  backup="$1"
  [[ -d "$backup" ]] || { echo "Backup not found: $backup" >&2; exit 1; }
  if [[ -d "$backup/home" ]]; then
    find "$backup/home" -type f -print | while IFS= read -r saved; do
      rel="${saved#"$backup/home/"}"
      target="$HOME/$rel"
      mkdir -p "$(dirname "$target")"
      cp -a "$saved" "$target"
    done
  fi
  echo "Restored backup $(basename "$backup")"
}

run_python_module() {
  module="$1"
  shift
  python="$STATE_DIR/app/.venv/bin/python"
  if [[ ! -x "$python" ]]; then
    python="$(command -v python3 2>/dev/null || true)"
  fi
  [[ -n "$python" ]] || { echo "python3 not found" >&2; exit 1; }
  if [[ -d "$STATE_DIR/app" ]]; then
    PYTHONPATH="$STATE_DIR/app:${PYTHONPATH:-}" "$python" -m "$module" "$@"
  else
    "$python" -m "$module" "$@"
  fi
}

cmd="${1:-}"
case "$cmd" in
  status)
    launchctl print "$DOMAIN/$LABEL"
    ;;
  start)
    launchctl bootstrap "$DOMAIN" "$PLIST" 2>/dev/null || true
    launchctl kickstart -k "$DOMAIN/$LABEL"
    ;;
  stop)
    launchctl bootout "$DOMAIN/$LABEL" 2>/dev/null || launchctl bootout "$DOMAIN" "$PLIST" 2>/dev/null || true
    old_label="$(legacy_label)"
    old_plist="$(legacy_plist_path)"
    launchctl bootout "$DOMAIN/$old_label" 2>/dev/null || launchctl bootout "$DOMAIN" "$old_plist" 2>/dev/null || true
    ;;
  restart)
    "$0" stop
    "$0" start
    ;;
  logs)
    tail -n 120 -f "$STATE_DIR/logs/server.log" "$STATE_DIR/logs/server.err.log"
    ;;
  configure)
    shift
    subcommand="${1:-}"
    case "$subcommand" in
      hermes)
        shift
        run_python_module "agent_voice.hermes_config" "$@"
        ;;
      ""|-h|--help|help)
        echo "Usage: agent-voice configure hermes [options]"
        ;;
      *)
        echo "Unknown configure target: $subcommand" >&2
        echo "Usage: agent-voice configure hermes [options]" >&2
        exit 2
        ;;
    esac
    ;;
  restore)
    shift
    selected=""
    if [[ "${1:-}" == "--list" ]]; then
      find "$(backup_root)" -mindepth 1 -maxdepth 1 -type d 2>/dev/null | sort | xargs -n 1 basename
      exit 0
    fi
    if [[ "${1:-}" == "--backup" ]]; then
      [[ $# -ge 2 ]] || { echo "Missing backup id" >&2; exit 2; }
      selected="$(backup_root)/$2"
    elif [[ $# -gt 0 ]]; then
      echo "Unknown restore option: $1" >&2
      exit 2
    else
      selected="$(latest_backup)"
    fi
    [[ -n "$selected" ]] || { echo "No backups available" >&2; exit 1; }
    restore_backup "$selected"
    ;;
  uninstall)
    shift
    destroy_caches=0
    if [[ "${1:-}" == "--destroy-caches" ]]; then
      destroy_caches=1
    fi
    launchctl bootout "$DOMAIN/$LABEL" 2>/dev/null || launchctl bootout "$DOMAIN" "$PLIST" 2>/dev/null || true
    restore_or_remove_shim "agent-voice"
    restore_or_remove_shim "agent-speak"
    restore_or_remove_shim "agent-voice-summary"
    rm -f "$PLIST"
    rm -rf "$STATE_DIR/app" "$STATE_DIR/bin"
    if [[ "$destroy_caches" -eq 1 ]]; then
      rm -rf "$STATE_DIR/model-cache"
    fi
    remove_legacy_artifacts "$destroy_caches"
    echo "agent-voice uninstalled"
    ;;
  ""|-h|--help|help)
    usage
    ;;
  *)
    echo "Unknown command: $cmd" >&2
    usage >&2
    exit 2
    ;;
esac
